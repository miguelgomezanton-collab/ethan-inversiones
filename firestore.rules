rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Cada usuario solo puede leer y escribir dentro de su propio
    // documento /users/{su_uid}/... — nadie más puede ver sus datos,
    // ni siquiera con la apiKey pública del frontend.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
